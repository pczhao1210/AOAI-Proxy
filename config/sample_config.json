{
  "server": {
    "host": "0.0.0.0",
    "port": 3000,
    "adminPath": "/admin",
    "adminAuth": {
      "enabled": true,
      "username": "admin",
      "password": "admin"
    },
    "caddy": {
      "enabled": false,
      "domain": "proxy.example.com",
      "email": "admin@example.com",
      "httpsPort": 443,
      "upstreamHost": "127.0.0.1",
      "upstreamPort": 3000,
      "transport": {
        "dialTimeoutMs": 5000,
        "responseHeaderTimeoutMs": 45000,
        "keepAliveTimeoutMs": 120000
      }
    },
    "imageCompression": {
      "enabled": true,
      "maxSize": 1600,
      "quality": 0.85,
      "format": "jpeg"
    },
    "upstream": {
      "connectTimeoutMs": 10000,
      "requestTimeoutMs": 900000,
      "firstByteTimeoutMs": 300000,
      "idleTimeoutMs": 900000,
      "maxRetries": 0,
      "retryBaseMs": 800,
      "retryMaxMs": 8000,
      "retryStatuses": [408, 409, 425, 429, 500, 502, 503, 504],
      "pool": {
        "connections": 64,
        "keepAliveTimeoutMs": 60000,
        "keepAliveMaxTimeoutMs": 300000,
        "headersTimeoutMs": 300000,
        "bodyTimeoutMs": 0,
        "pipelining": 1
      }
    }
  },
  "auth": {
    "mode": "servicePrincipal",
    "tenantId": "",
    "clientId": "",
    "clientSecret": "",
    "managedIdentityClientId": "",
    "scope": "https://cognitiveservices.azure.com/.default",
    "apiKey": ""
  },
  "apiKeys": [
    {
      "id": "default",
      "key": "CHANGEME",
      "status": "active"
    }
  ],
  "upstreams": [
    {
      "name": "foundry",
      "baseUrl": "https://YOUR-RESOURCE-NAME.openai.azure.com/",
      "routes": {
        "chat/completions": "/openai/v1/chat/completions",
        "responses": "/openai/v1/responses",
        "images/generations": "/openai/v1/images/generations"
      }
    }
  ],
  "models": [
    {
      "id": "gpt-5-mini",
      "upstream": "foundry",
      "targetModel": "gpt-5-mini",
      "routes": {}
    },
    {
      "id": "gpt-5.2-codex",
      "upstream": "foundry",
      "targetModel": "gpt-5.2-codex",
      "routes": {
        "*": "responses"
      }
    }
  ]
}
